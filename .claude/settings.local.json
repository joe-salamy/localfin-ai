{
  "permissions": {
    "allow": [
      "Bash(npm create:*)",
      "Bash(cp -r ai-budget-temp/* ai-budget-app-v2/)",
      "Bash(cp ai-budget-temp/.gitignore ai-budget-app-v2/)",
      "Bash(cp -r ai-budget-temp/. ai-budget-app-v2/)",
      "Bash(rm -rf ai-budget-temp)",
      "Bash(npm install:*)",
      "Bash(timeout 10 npx tsx server/index.ts)",
      "Bash(npx tsx:*)",
      "Bash(rm test-db.ts)",
      "Bash(rm -f data/budget.db)",
      "Bash(npx tsc:*)",
      "Bash(curl -s http://localhost:3001/api/health)",
      "Bash(curl -s http://localhost:3001/api/accounts)",
      "Bash(curl -s http://localhost:3001/api/categories)",
      "Bash(curl -s -X POST http://localhost:3001/api/accounts -H \"Content-Type: application/json\" -d '{\"name\":\"Checking\",\"type\":\"asset\",\"initial_balance\":1000}')",
      "Bash(curl -s -X POST http://localhost:3001/api/accounts -H \"Content-Type: application/json\" -d '{\"name\":\"Checking\",\"type\":\"asset\",\"initial_balance\":5000}')",
      "Bash(curl -s -X POST http://localhost:3001/api/categories -H \"Content-Type: application/json\" -d '{\"name\":\"Food\",\"type\":\"expense\"}')",
      "Bash(taskkill //F //IM node.exe)",
      "Bash(echo \"exit: $?\")"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import sys,json,subprocess; d=json.load(sys.stdin); f=d.get('tool_input',{}).get('file_path',''); r=subprocess.run(['python','-m','py_compile',f],capture_output=True,text=True) if f.endswith('.py') else None; r and r.returncode and (sys.stderr.write(r.stderr) or sys.exit(r.returncode))\"",
            "statusMessage": "Checking syntax..."
          }
        ]
      }
    ]
  }
}
